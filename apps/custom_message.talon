show my message:
    user.custom_message_notify("info", "Mixed Mode Is: Great", 0, False, False, "Talon Voice Modes")
hide my message: user.custom_message_clear()

copy custom message: user.custom_message_copy_current()

keep custom message open: user.custom_message_keep_open()

release custom message: user.custom_message_release()

hide custom message: user.custom_message_clear()

custom message help: user.custom_message_show_help()
